# La Boît'à Soif — variables d'environnement (Vite)
# Copier ce fichier en `.env` et renseigner les valeurs de VOTRE projet Supabase
# (projet dédié à la Boît'à Soif — pas celui d'une autre app).
# La clé "publishable"/anon est publique (incluse dans le bundle), mais on garde
# le .env hors du dépôt pour ne pas figer la config d'un projet dans le repo.

VITE_SUPABASE_PROJECT_ID="votre-project-id"
VITE_SUPABASE_URL="https://votre-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="votre-cle-anon-publishable"
